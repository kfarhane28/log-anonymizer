{
  "version": 1,
  "description": "Example anonymization rules for Hadoop/Cloudera logs. Tune for your environment.",
  "hash": {
    "prefix": "anon_",
    "length": 16
  },
  "rules": [
    {
      "name": "kerberos_service_principal",
      "pattern": "\\b[A-Za-z0-9._-]+/[A-Za-z0-9._-]+@[A-Za-z0-9._-]+\\b",
      "action": "hash"
    },
    {
      "name": "kerberos_user_principal",
      "pattern": "\\b[A-Za-z0-9._-]+@[A-Za-z0-9._-]+\\b",
      "action": "hash"
    },
    {
      "name": "email",
      "pattern": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
      "action": "hash"
    },
    {
      "name": "hdfs_user_path",
      "pattern": "(?i)(/user/)([A-Za-z0-9._-]+)(/)",
      "action": "replace",
      "replacement": "\\1[USER]\\3"
    },
    {
      "name": "ipv4",
      "pattern": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b",
      "action": "hash"
    },
    {
      "name": "uuid",
      "pattern": "\\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b",
      "action": "hash"
    },
    {
      "name": "user_equals",
      "pattern": "(?i)\\buser\\s*=\\s*([A-Za-z0-9._-]+)\\b",
      "action": "replace",
      "replacement": "user=[USER]"
    },
    {
      "name": "bearer_token",
      "pattern": "(?i)\\bBearer\\s+([A-Za-z0-9._-]+)\\b",
      "action": "token",
      "token": "Bearer [REDACTED]"
    }
  ]
}
