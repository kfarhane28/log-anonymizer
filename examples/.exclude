# Exclude common non-log artifacts and large/binary blobs from processing.
*.jar
*.class
*.parquet
*.orc
*.avro
*.snappy
*.gz
*.bz2
*.xz
*.7z
*.tar
*.tgz
*.zip

# Exclude common credential/key material often present in Hadoop/Cloudera bundles.
creds.localjceks
creds.localjceks.sha
*.jceks
*.jceks.sha
*.keytab
krb5.conf
jaas.conf
*.jks
*keystore*
*truststore*
*.p12
*.pfx
*.pem
*.key
*.crt
*.cer
*.der
*.kdb

# Skip node/yarn cache and application history caches if present in support bundles.
**/.yarn/**
**/.cache/**
**/yarn-cache/**

# Example: exclude all stack traces, but keep one specific file.
**/*stacktrace*
!**/important-stacktrace.log
