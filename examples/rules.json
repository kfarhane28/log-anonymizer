{
  "version": 1,
  "rules": [
    {
      "description": "HDFS /user/<name>/ path",
      "trigger": "/user/",
      "search": "(?i)(/user/)([A-Za-z0-9._-]+)(/)",
      "replace": "\\1[USER]\\3",
      "caseSensitive": "false"
    },
    {
      "description": "user=... (key/value)",
      "trigger": "user=",
      "search": "(?i)\\buser\\s*=\\s*([A-Za-z0-9._-]+)\\b",
      "replace": "user=[USER]",
      "caseSensitive": "false"
    },
    {
      "description": "Bearer token",
      "trigger": "Bearer ",
      "search": "(?i)\\bBearer\\s+\\S+\\b",
      "replace": "Bearer [REDACTED]",
      "caseSensitive": "false"
    }
  ]
}

