{
  "version": 1,
  "rules": [
    {
      "description": "Email address",
      "trigger": "@",
      "search": "\\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}\\b",
      "replace": "[EMAIL]",
      "caseSensitive": "true"
    },
    {
      "description": "HDFS /user/<name>/ path",
      "trigger": "/user/",
      "search": "(?i)(/user/)([A-Za-z0-9._-]+)(/)",
      "replace": "\\1[USER]\\3",
      "caseSensitive": "false"
    },
    {
      "description": "Absolute file path",
      "trigger": "/",
      "search": "(?<![A-Za-z0-9_])/(?:[A-Za-z0-9._-]+/){2,}[A-Za-z0-9._-]+",
      "replace": "[PATH]",
      "caseSensitive": "true"
    },
    {
      "description": "Hostname (cdc.fr)",
      "trigger": "cdc.fr",
      "search": "(?i)\\b(?:[A-Za-z0-9](?:[A-Za-z0-9-]{0,61}[A-Za-z0-9])?\\.)+cdc\\.fr\\b",
      "replace": "[HOST]",
      "caseSensitive": "false"
    },
    {
      "description": "UUID",
      "trigger": "-",
      "search": "\\b[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}\\b",
      "replace": "[UUID]",
      "caseSensitive": "true"
    },
    {
      "description": "Person token (e.g. csoprasteriabq-e)",
      "trigger": "-",
      "search": "\\b[a-z]{12,}-[a-z]\\b",
      "replace": "[PERSON]",
      "caseSensitive": "true"
    },
    {
      "description": "uid=... (key/value)",
      "trigger": "uid=",
      "search": "(?i)\\buid\\s*=\\s*([A-Za-z0-9._-]+)\\b",
      "replace": "uid=[USER]",
      "caseSensitive": "false"
    },
    {
      "description": "user=... (key/value)",
      "trigger": "user=",
      "search": "(?i)\\buser\\s*=\\s*([A-Za-z0-9._-]+)\\b",
      "replace": "user=[USER]",
      "caseSensitive": "false"
    },
    {
      "description": "Bearer token",
      "trigger": "Bearer ",
      "search": "(?i)\\bBearer\\s+\\S+\\b",
      "replace": "Bearer [REDACTED]",
      "caseSensitive": "false"
    }
  ]
}